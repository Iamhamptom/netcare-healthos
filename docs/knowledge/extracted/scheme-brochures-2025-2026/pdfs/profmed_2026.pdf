<script>(function() {
    // 1. Get the value from the URL
    const urlParams = new URLSearchParams(window.location.search);
    const marketingStream = urlParams.get('marketing_stream');

    if (marketingStream) {
        // 2. Listen for Ninja Forms to initialize any form on the page
        jQuery(document).on('nfFormReady', function(e, layoutView) {
            
            // 3. Find the field model by its Key
            const fieldModel = layoutView.model.get('fields').findWhere({ key: 'utm_marketing_stream' });

            if (fieldModel) {
                // 4. Set the value in the Ninja Forms model directly
                fieldModel.set('value', marketingStream);
                
                // 5. Force the UI to update so the webhook sees it
                const fieldView = layoutView.children.findByModel(fieldModel);
                if (fieldView) {
                    jQuery(fieldView.el).find('input').val(marketingStream).trigger('change');
                }
                
                console.log('Ninja Forms: Successfully injected "' + marketingStream + '" into utm_marketing_stream');
            } else {
                console.warn('Ninja Forms: Field key "utm_marketing_stream" not found in this form.');
            }
        });
    }
})();
