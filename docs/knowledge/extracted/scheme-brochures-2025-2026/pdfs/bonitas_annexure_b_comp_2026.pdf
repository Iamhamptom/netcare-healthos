					<script>
  document.addEventListener("DOMContentLoaded", function () {
      
      //hide quote on home page
const btnMainQuote = document.getElementById("btnMainQuote");

  if (window.location.pathname === "/" && btnMainQuote) {
    btnMainQuote.style.display = "none";
    console.log("✅ btnMainQuote hidden on home page");
  }
      
    const rows = document.querySelectorAll('.uc_material_bullets_row');
    if (rows.length) {
      rows[0].classList.add('is-first');
      rows[rows.length - 1].classList.add('is-last');
    }
    

  const currentUrl = window.location.pathname.replace(/\/$/, ""); // remove trailing slash
  document.querySelectorAll(".uc-mega-menu a").forEach(link => {
    const linkPath = new URL(link.href).pathname.replace(/\/$/, "");
    if (linkPath === currentUrl) {
      link.classList.add("active");
    }

});
  });
</script>
