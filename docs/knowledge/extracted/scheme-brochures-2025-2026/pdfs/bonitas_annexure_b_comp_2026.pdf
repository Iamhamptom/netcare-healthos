<!-- End Google Tag Manager --><script>jQuery(document).ready(function($) {
  const $filterContainer = $('#uc_ue_buttons_post_filter_elementor_4e7695b'); // your UE Tabs Filter container
  
  // --- 1️⃣ SVGs for Videos & Documents ---
  const videoIcon = `
    <span class="elementor-button-icon ue-custom-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M5 17.3336V6.66698C5 5.78742 5 5.34715 5.18509 5.08691C5.34664 4.85977 5.59564 4.71064 5.87207 4.67499C6.18868 4.63415 6.57701 4.84126 7.35254 5.25487L17.3525 10.5882L17.3562 10.5898C18.2132 11.0469 18.642 11.2756 18.7826 11.5803C18.9053 11.8462 18.9053 12.1531 18.7826 12.4189C18.6418 12.7241 18.212 12.9537 17.3525 13.4121L7.35254 18.7454C6.57645 19.1593 6.1888 19.3657 5.87207 19.3248C5.59564 19.2891 5.34664 19.1401 5.18509 18.9129C5 18.6527 5 18.2132 5 17.3336Z"
        stroke="#BA0D36" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  `;

  const docIcon = `
    <span class="elementor-button-icon ue-custom-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 40 40" fill="none">
        <path d="M20.0002 20.0002V30.0002M20.0002 30.0002L25.0002 26.6669M20.0002 30.0002L15.0002 26.6669M21.6668 5.00169C21.5077 5.00024 21.329 5.00024 21.1247 5.00024H13.6672C11.8003 5.00024 10.8662 5.00024 10.1532 5.36356C9.52595 5.68313 9.01639 6.1927 8.69681 6.81991C8.3335 7.53294 8.3335 8.46706 8.3335 10.3339V29.6672C8.3335 31.5341 8.3335 32.467 8.69681 33.1801C9.01639 33.8073 9.52595 34.3177 10.1532 34.6373C10.8655 35.0002 11.7985 35.0002 13.6617 35.0002H26.3386C28.2018 35.0002 29.1335 35.0002 29.8458 34.6373C30.473 34.3177 30.9843 33.8072 31.3039 33.18C31.6668 32.4677 31.6668 31.5361 31.6668 29.6729V15.543C31.6668 15.3385 31.6668 15.1596 31.6653 15.0002M21.6668 5.00169C22.1429 5.00603 22.4441 5.02332 22.7316 5.09234C23.0717 5.174 23.3966 5.30902 23.6948 5.49178C24.0311 5.69785 24.3199 5.98661 24.896 6.56274L30.1051 11.7719C30.6816 12.3484 30.9683 12.6358 31.1744 12.9722C31.3572 13.2705 31.4924 13.5957 31.5741 13.9358C31.6431 14.2232 31.6607 14.5244 31.6653 15.0002M21.6668 5.00169V9.66691C21.6668 11.5338 21.6668 12.4665 22.0301 13.1796C22.3497 13.8068 22.8593 14.3177 23.4865 14.6373C24.1988 15.0002 25.1318 15.0002 26.995 15.0002H31.6653M31.6653 15.0002H31.6672"
        stroke="#BA0D36" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </span>
  `;

  // --- 2️⃣ Add icons next to button titles ---
  $filterContainer.find('.ue_taxonomy_item').each(function() {
    const $btn = $(this);
    const title = $btn.find('.ue_taxonomy_item_title').text().trim().toLowerCase();

    // add icons only if not already present
    if (!$btn.find('.ue-custom-icon').length) {
      if (title === 'videos') {
        $btn.find('.ue_taxonomy_item_icon_spacer').before(videoIcon);
      } else if (title === 'documents') {
        $btn.find('.ue_taxonomy_item_icon_spacer').before(docIcon);
      }
    }
  });

  // --- 3️⃣ Custom sort order ---
  const order = ['all content', 'documents', 'videos']; // custom priority list
  const $buttons = $filterContainer.find('.ue_taxonomy_item').get();

  $buttons.sort(function(a, b) {
    const titleA = $(a).find('.ue_taxonomy_item_title').text().trim().toLowerCase();
    const titleB = $(b).find('.ue_taxonomy_item_title').text().trim().toLowerCase();

    const indexA = order.indexOf(titleA) === -1 ? 999 : order.indexOf(titleA);
    const indexB = order.indexOf(titleB) === -1 ? 999 : order.indexOf(titleB);

    if (indexA !== indexB) return indexA - indexB;
    return titleA.localeCompare(titleB);
  });

  $filterContainer.append($buttons); // re-append in the new order
});




