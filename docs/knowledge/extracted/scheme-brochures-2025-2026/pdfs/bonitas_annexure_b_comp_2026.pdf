}setTimeout(function(){if(jQuery("#uc_post_list_elementor_3093f7e6").length) uc_post_list_elementor_3093f7e6_start(); else
	jQuery( document ).on( 'elementor/popup/show', () => { if(jQuery("#uc_post_list_elementor_3093f7e6").length) uc_post_list_elementor_3093f7e6_start();});},100);
});

