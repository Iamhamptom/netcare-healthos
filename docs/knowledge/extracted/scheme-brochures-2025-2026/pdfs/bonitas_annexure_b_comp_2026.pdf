/* ==== Equal Height Fix for UE Resource Cards ==== */

/* The holder behaves as a flexible grid */
.resource-holder {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 24px; /* match your UE grid gap */
}

.resource-holder .resource-item{
	height:100% !important;
}

/* Each card acts as a self-stretching flex child */
.resource-holder .resource-item.loop-item {
  display: flex !important;
  flex-direction: column !important;
  align-items: stretch !important;
  flex: 1 1 calc(33.333% - 24px); /* 3 columns, adjust as needed */
  box-sizing: border-box;
}

/* Inner container should stretch fully */
.resource-holder .resource-item.loop-item > .e-con-inner {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

/* Push bottom content to the base of the card */
.resource-holder .resource-item.loop-item .elementor-element-b15c536 {
  margin-top: auto !important;
}

/* Optional smooth visual consistency */
.resource-holder .resource-item.loop-item {
  transition: all 0.2s ease-in-out;
}

.resource-holder .e-loop-item{
	height:100% !important;
}

.resource-holder .loop-item .e-con-full{
	margin-top: 0 !important;
    height: 100%;
}

.resource-btn .elementor-button-icon{
	font-size: 22px;
    margin-top: -4px;
}

@media (max-width: 1024px) {
  .resource-holder .resource-item.loop-item {
    flex: 1 1 calc(50% - 24px);
  }
}
@media only screen and (max-width: 767px) {
	.resource-holder .e-loop-item {
		height: auto !important;
	}
}
@media (max-width: 767px) {
  .resource-holder .resource-item.loop-item {
    flex: 1 1 100%;
  }
}

/* ---- temporary visibility patch ---- */
.uc_material_accordion .ue_accordion_content {
  display: none;
  overflow: hidden;
  transition: all 0.3s ease;
}

.uc_material_accordion .uc-heading.active + .ue_accordion_content {
  display: block !important;
}



.search-results .elementor-post__thumbnail{
	max-height:200px !important;
	overflow:hidden;
}

