<style>/* widget: Post List */



#uc_post_list_elementor_3093f7e6{
  display:grid;
}

#uc_post_list_elementor_3093f7e6 .uc_post_list_image div{
  background-size:cover;
  background-position:center;
}

.uc_post_list .uc_post_list_box{
	position: relative;
	overflow: hidden;
	display: flex;
}

#uc_post_list_elementor_3093f7e6 .uc_post_list_image{
  flex-grow:0;
  flex-shrink:0;
  overflow: hidden;
}

#uc_post_list_elementor_3093f7e6 .uc_post_list_image img{
  width:100%;
  height:100%;
  display:block;
  transition:0.3s;  
  position: relative;
  z-index: 1;
}

.uc_post_list_title a{
    position: relative;
    z-index: 1;
	color: #333333;
    display: block;
}

.uc_post_list_date{
	font-size: 12px;
}

#uc_post_list_elementor_3093f7e6 .uc_post_list_content{
  display:flex;
  flex-direction:column;
  flex:1;
}

#uc_post_list_elementor_3093f7e6 .uc_more_btn{
  text-align:center;
  text-decoration:none;
  transition:0.3s;
  position: relative;
  z-index: 1;
}

#uc_post_list_elementor_3093f7e6 .button-on-side{
  display:flex;
