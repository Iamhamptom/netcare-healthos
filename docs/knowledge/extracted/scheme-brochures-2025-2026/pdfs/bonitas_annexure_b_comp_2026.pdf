<style>/* widget: Mega Menu */


#uc_mega_menu_elementor_6e409f6{
  position: relative;
}

#uc_mega_menu_elementor_6e409f6 *{
  box-sizing:border-box;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_list{
  display: flex;
  list-style: none;
  padding:0px;
  margin: 0;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section{
  position: absolute;
  z-index: 99997;
  top: 100%;
  left: 50%;
  transform: translate(-50%, 0);
  padding-top: 0px;
  pointer-events: none;
  overflow: hidden;
  visibility: hidden;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section-cover{
  position: absolute;
  z-index: 99996;
  pointer-events: none;
    top: calc(100% + 0px);
    opacity: 0;
  pointer-events: none;
  transition: opacity 250ms;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu-wrapper  {
    left: 0;
    top: 0;
    height: 100%;
    position: relative;
    z-index: 99999;
    overflow-y: visible;
}

  #uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section{
      left: 50%;
      transform: translate(calc(-50% + 0px), 0);
      padding-top: 0px;
    }
    #uc_mega_menu_elementor_6e409f6 .uc-mega_menu_list_item{
        position: relative;
    }

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section.section-error .uc-section-error{
  	text-align: center;
  	min-height: 400px;
  	padding: 15px;
  	display: flex;
  	justify-content: center;
  	align-items: center;
  	background-color: #cccccc;
  	position: relative;
  	z-index: 99997;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_title{
  	display: flex;
  	gap: 5px;
  	align-items: center;
  		
    position:relative;
  	z-index: 99998;
}	

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_list_item,
#uc_mega_menu_elementor_6e409f6 .uc-active_item .uc-mega_menu_title{
  transition: all 0.3s;
  text-align: center;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_list{
	width: 100%;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section.uc-active_item{
  pointer-events: all;
  z-index: 99998;
  visibility: visible;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu_section.uc-active_item + .uc-mega_menu_section-cover{
	opacity: 1;
    pointer-events: all;
}

#uc_mega_menu_elementor_6e409f6 .uc-error{
  color: red;
  font-weight: 700;
}

#uc_mega_menu_elementor_6e409f6 .uc-message{
	text-align: center;
}

#uc_mega_menu_elementor_6e409f6 .uc-mega_menu-wrapper.uc-menu-open{
  transform: translate(0, 0);
}

#uc_mega_menu_elementor_6e409f6 .uc_mega_menu_overlay{
  cursor: default;
  display: none;
  position: absolute;
  top: calc(100% + 0px);
  left: 0;
  transition: opacity 0.3s;
  z-index: 99995;
