					<style>
    #members .ue-graphic-element{
        background-color: transparent;
    }
  .hover-content {
    position: absolute;
    left: 0;
    top: 0; /* Or wherever it makes sense visually */
    width: 100%;
    opacity: 0;
    transform: translateX(100%);
    transition: all 0.7s ease;
    display: inherit; /* Always block to allow transition */
    z-index: 1;
    pointer-events: none;
  }

  .hover-content.active {
    opacity: 1;
    transform: translateX(0);
    z-index: 2;
    pointer-events: auto;
  }

  .hover-content.exit-left {
    transform: translateX(-100%);
    opacity: 0;
  }

  .hover-content.exit-right {
    transform: translateX(100%);
    opacity: 0;
  }

  .hover-zone {
    position: relative;
    height: 200px; /* Adjust height to fit content */
    overflow: hidden;
  }
  /* Mobile responsiveness */
    @media screen and (max-width: 767px) {
        #main-container {
            display: none !important;
        }
        #mobi-container {
            display: block !important;
        }
    }

    /* Default (desktop-first approach) */
    #mobi-container {
        display: none;
    }
    
   .uc-mega_menu_section > *{
        padding:10px 0 0 !important;
    }


</style>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    
   const triggers = document.querySelectorAll(".hover-trigger");
    const containers = document.querySelectorAll(".hover-content");
    let currentId = null;

    triggers.forEach(trigger => {
      trigger.addEventListener("mouseenter", function () {
        const newId = trigger.getAttribute("data-id");
        if (currentId === newId) return;

        const newEl = document.getElementById(newId);
        const currentEl = currentId ? document.getElementById(currentId) : null;

        // Slide out current
        if (currentEl) {
          currentEl.classList.remove("active");
          currentEl.classList.add("exit-left"); // or exit-right depending on your preference
          setTimeout(() => {
            currentEl.classList.remove("exit-left", "exit-right");
          }, 700); // match the transition duration
        }

        // Slide in new
        if (newEl) {
          newEl.classList.add("active");
        }

        currentId = newId;
      });
    });
    
  });

</script>				</div>
				</div>
					</div>
				</div>
				</div>
		
