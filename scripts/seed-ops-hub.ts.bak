/**
 * Seed the Operations Hub with all existing research, leads, session summaries, and strategies.
 * Run: npx tsx scripts/seed-ops-hub.ts
 */

import { PrismaClient } from "../src/generated/prisma/client.js";
import { PrismaBetterSqlite3 } from "@prisma/adapter-better-sqlite3";
import fs from "fs";
import path from "path";

const adapter = new PrismaBetterSqlite3({ url: "file:./dev.db" });
const prisma = new PrismaClient({ adapter });

async function main() {
  console.log("Seeding Operations Hub...\n");

  // Clear existing ops documents
  const existing = await prisma.opsDocument.count();
  if (existing > 0) {
    console.log(`Clearing ${existing} existing ops documents...`);
    await prisma.opsDocument.deleteMany();
  }

  const rootDir = process.cwd();

  // Helper to read file content
  function readFile(filename: string): string {
    const filePath = path.join(rootDir, filename);
    if (!fs.existsSync(filePath)) {
      console.warn(`  WARNING: File not found: ${filePath}`);
      return `[File not found: ${filename}]`;
    }
    return fs.readFileSync(filePath, "utf-8");
  }

  const documents: {
    category: string;
    title: string;
    content: string;
    tags: string[];
    pinned: boolean;
  }[] = [];

  // ============================================================
  // RESEARCH CATEGORY
  // ============================================================

  // Document 1: SA Healthcare Marketing Compliance Guide
  documents.push({
    category: "research",
    title: "SA Healthcare Marketing Compliance Guide",
    content: readFile("SA-Healthcare-Marketing-Compliance-Guide.md"),
    tags: ["compliance", "hpcsa", "popia", "icd-10", "marketing", "sa-law"],
    pinned: true,
  });

  // Document 2: SA Private Practice Economics
