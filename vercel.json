{
  "redirects": [
    {
      "source": "/",
      "destination": "https://healthops-platform.vercel.app/demo",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/reminders/run",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/claims/retention",
      "schedule": "0 3 1 * *"
    },
    {
      "path": "/api/reports/run",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/ml/reinforce",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/ml/registry-update",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/engagement/cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/engagement/email/poll",
      "schedule": "0 */2 * * *"
    }
  ]
}
